# Configuración de Base de Datos
DATABASE_URL=postgres://usuario:password@host:port/nombre_bd

# Configuración de IA Gemini
GEMINI_API_KEY=tu_api_key_aqui
AI_MODEL=gemini-2.0-flash

# Servidor
PORT=8080

# Notificaciones Email
EMAIL_ENABLED=true
RESEND_API_KEY=re_tua_api_key_aqui
EMAIL_FROM=M7 Apps <admin@m7apps.com>
EMAIL_HOST=tu_host_smtp
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=tu_email@dominio.com
EMAIL_PASSWORD=tu_password_seguro

# WhatsApp Evolution API
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=tu_api_key_evolution

# Evolution Legacy (fallback)
EVO_API_URL=http://waha:3000
EVO_API_KEY=tu_api_key_waha
EVO_INSTANCE=NombreInstancia

# Modo Demo para Frontend
VITE_APP_DEMO_MODE=false
VITE_APP_DEMO_EMAIL=
VITE_APP_DEMO_PASSWORD=
