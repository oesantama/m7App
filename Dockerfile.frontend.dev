# ──────────────────────────────────────────────────────────
# M7 Frontend — Imagen de DESARROLLO con Vite HMR
# No usar en producción. Ver Dockerfile.frontend para prod.
# ──────────────────────────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Copiar manifiestos e instalar TODAS las dependencias
COPY package*.json ./
RUN npm install --legacy-peer-deps --no-audit --ignore-scripts

# Copiar código fuente inicial
# (será sobreescrito por volume mounts en docker-compose.dev.yml)
COPY . .

EXPOSE 5173

# Vite dev server con HMR habilitado para acceso desde el host
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
