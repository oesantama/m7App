{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "outDir": "./dist_backend",
        "strict": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": false
    },
    "include": [
        "backend/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist_backend",
        "src",
        "**/*.test.ts",
        "backend/tests/**/*",
        "backend/debug_*.ts",
        "backend/test_*.ts",
        "backend/fix_*.ts",
        "backend/inspect_*.ts",
        "backend/read_*.ts",
        "backend/telemetry_*.ts",
        "backend/*.js",
        "backend/*.cjs",
        "backend/list_models.ts"
    ]
}