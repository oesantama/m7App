FROM atendai/evolution-api:latest
# Delete all .env files at build time so Prisma cannot load them
RUN find /evolution -name ".env" -type f -delete 2>/dev/null; true
COPY evolution-entrypoint.sh /usr/local/bin/evolution-entrypoint.sh
RUN chmod +x /usr/local/bin/evolution-entrypoint.sh
ENTRYPOINT ["/usr/local/bin/evolution-entrypoint.sh"]
